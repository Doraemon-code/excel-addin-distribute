<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Excel 加载项 CustomUI 示例

  使用方法：
  1. 用 Office RibbonX Editor 打开 xlam 文件
  2. 右键 → Insert → Insert Office 2010+ Custom UI Part
  3. 将此文件内容粘贴到编辑区
  4. 点击 Validate 确认无错误
  5. 点击 Save 保存

  注意：所有 onAction 指向的函数必须在 VBA 中定义为：
  Public Sub 函数名(control As IRibbonControl)
-->
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="tab_MyTools" label="小叮当当" insertAfterMso="TabHome">

        <!-- 目录 -->
        <group id="grp_Index" label="目录" autoScale="true">
          <button id="btn_GenerateIndex" label="生成目录" imageMso="SlidesPerPageSlideOutline" onAction="GenerateIndex" visible="true"/>
          <button id="btn_JumpSheetIndex" label="回到目录" imageMso="OutlinePromoteToHeading" onAction="JumpSheetIndex" visible="true"/>
        </group>

        <!-- 格式化 -->
        <group id="grp_Format" label="格式化" autoScale="true">
          <button id="btn_FirstObsFormat" label="首行格式化" imageMso="WindowUnhide" onAction="FirstObsFormat" visible="true"/>
          <button id="btn_FontFormat" label="字体格式化" imageMso="ViewSheetGridlines" onAction="FontFormat" visible="true"/>
          <button id="btn_RemoveAllAutoFilters" label="移除筛选" imageMso="FormatPainter" onAction="RemoveAllAutoFilters" visible="true"/>
          <button id="btn_RemoveLineBreaks" label="移除换行符" imageMso="ChangeBinding" onAction="RemoveLineBreaks" visible="true"/>
        </group>

        <!-- 汇总 -->
        <group id="grp_Summary" label="汇总" autoScale="true">
          <button id="btn_Classification" label="分类计数" imageMso="BlackAndWhiteInverseGrayscale" onAction="Classification" visible="true"/>
          <button id="btn_DupSum" label="去重计数" imageMso="Chart3DBarChart" onAction="DupSum" visible="true"/>
        </group>

        <!-- 正则 -->
        <group id="grp_Regex" label="正则" autoScale="true">
          <button id="btn_ExtractTextByRegex" label="正则提取" imageMso="AppointmentColor10" onAction="ExtractTextByRegex" visible="true"/>
        </group>

        <!-- MedDRA -->
        <group id="grp_MedDRA" label="MedDRA" autoScale="true">
          <button id="btn_SortAndGroupCount" label="同义词检测" imageMso="ListMacros" onAction="SortAndGroupCount" visible="true"/>
        </group>

        <!-- 帮助 -->
        <group id="grp_Help" label="帮助" autoScale="true">
          <button id="btn_ShowHelp" label="CallMe" imageMso="HighImportance" onAction="ShowHelp" visible="true"/>
        </group>

      </tab>
    </tabs>
  </ribbon>
</customUI>